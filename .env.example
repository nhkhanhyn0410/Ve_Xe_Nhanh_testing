# Copy this file to `.env` if you want to customize the Docker setup.
# If you change the ports below, also update the related URLs.

FRONTEND_PORT=3000
BACKEND_PORT=5000
MONGO_PORT=27017
ME_PORT=8081
REDIS_PORT=6379

MONGODB_URI=mongodb://mongodb:27017/vexenhanh
ME_CONFIG_MONGODB_URL=mongodb://mongodb:27017/
REDIS_URL=redis://redis:6379

NODE_ENV=production
API_VERSION=v1
JWT_SECRET=change-this-jwt-secret-to-a-long-random-value
ADMIN_BOOTSTRAP_SECRET=

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VITE_API_URL=/api/v1

EMAIL_ENABLED=false
SMS_ENABLED=false
DEMO_MODE=true

PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_FAILURE_URL=http://localhost:3000/payment/failure
PAYMENT_ERROR_URL=http://localhost:3000/payment/error
